{
  "uid": "kafka-performance",
  "title": "Kafka Performance",
  "description": "Topic-level lag, RPS, ETA. Uses Kafka consumer JMX metrics: kafka_consumer_fetch_manager_records_lag, kafka_consumer_fetch_manager_records_consumed_total (labels: client_id, topic, partition).",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "client_id",
        "label": "Client ID",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
        "query": "label_values(kafka_consumer_fetch_manager_records_lag, client_id)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "topic",
        "label": "Topic",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
        "query": "label_values(kafka_consumer_fetch_manager_records_lag{client_id=~\"$client_id\"}, topic)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Topic: Lag, RPS, ETA",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "expr": "sum by (topic) (kafka_consumer_fetch_manager_records_lag{client_id=~\"$client_id\", topic=~\"$topic\"})",
          "refId": "Lag",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (topic) (rate(kafka_consumer_fetch_manager_records_consumed_total{client_id=~\"$client_id\", topic=~\"$topic\"}[1m]))",
          "refId": "RPS",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (topic) (kafka_consumer_fetch_manager_records_lag{client_id=~\"$client_id\", topic=~\"$topic\"}) / clamp_min(sum by (topic) (rate(kafka_consumer_fetch_manager_records_consumed_total{client_id=~\"$client_id\", topic=~\"$topic\"}[1m])), 0.001)",
          "refId": "ETA",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": { "byField": "topic" } },
        { "id": "organize", "options": { "renameByName": { "topic": "Topic" } } }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ETA" },
            "properties": [
              { "id": "unit", "value": "s" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 300 },
                    { "color": "orange", "value": 3600 },
                    { "color": "red", "value": 86400 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Lag" },
            "properties": [
              { "id": "unit", "value": "short" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 10000 },
                    { "color": "red", "value": 100000 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Lag by topic",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "expr": "sum by (topic) (kafka_consumer_fetch_manager_records_lag{client_id=~\"$client_id\", topic=~\"$topic\"})",
          "refId": "A",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "RPS by topic (msg/s)",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "expr": "sum by (topic) (rate(kafka_consumer_fetch_manager_records_consumed_total{client_id=~\"$client_id\", topic=~\"$topic\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 }
    }
  ]
}
